datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  transactions Transaction[]
  budgets      Budget[]
  messages     ChatMessage[]
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  description String
  amount      Float
  category    String
  source      String   // MANUAL / UPLOAD
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Budget {
  id           String   @id @default(cuid())
  userId       String
  category     String
  monthlyLimit Float
  month        String   // e.g. "2026-04"
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // USER / AI
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
